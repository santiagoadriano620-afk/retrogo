# ══════════════════════════════════════════════════════════════════════════════
# IMPORTANT: Copy this file to .env and fill in your values before running!
# NEVER commit .env to version control. NEVER use real secrets in .env.example.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Security ────────────────────────────────────────────────────────────────
# Generate a secure random key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# Admin API secret (used internally between admin panel and engine)
# Same command as above
ADMIN_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# Admin panel session secret (used to sign cookies)
SESSION_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# ─── TLS/SSL ─────────────────────────────────────────────────────────────────
# Paths to cert and key files. Leave empty for HTTP only.
# TLS_CERT=/etc/ssl/certs/tibia.crt
# TLS_KEY=/etc/ssl/private/tibia.key

# ─── Server ───────────────────────────────────────────────────────────────────
# Public-facing address the client uses to connect via WebSocket
EXTERNAL_HOST=ws://localhost:2223

# Login server port (HTTP/HTTPS for client files + auth)
LOGIN_PORT=8000
LOGIN_HOST=0.0.0.0

# Game server port (WebSocket)
GAME_PORT=2223
GAME_HOST=0.0.0.0

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to false for production
DEV_MODE=false

# ─── Game Rates ───────────────────────────────────────────────────────────────
RATE_EXPERIENCE=1
RATE_SKILL=1
RATE_LOOT=1
RATE_MAGIC=1
RATE_SPAWN=1

# ─── Client Server (alternative cluster mode) ────────────────────────────────
CLIENT_PORT=8000
CLIENT_HOST=0.0.0.0
CLIENT_WORKERS=1
# Where the client-server proxies login requests to
LOGIN_SERVER=http://localhost:8000

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Get your keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get from Stripe Dashboard > Webhooks > Add endpoint
# STRIPE_WEBHOOK_SECRET=whsec_...
